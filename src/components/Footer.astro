---
import { footerLinks, site } from "@/lib/site";
---

<footer class="bg-brand">
  <div class="section-wrap pb-8 pt-14 text-white">
    <div class="grid gap-10 md:grid-cols-4">
      <div>
        <h2 class="font-display text-xl font-bold text-white">Navigation</h2>
        <ul class="mt-4 grid gap-2 text-sm">
          {
            footerLinks.map((item) => (
              <li>
                <a href={item.href} class="text-muted hover:text-white">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <h2 class="font-display text-xl font-bold text-white">Kontakt</h2>
        <ul class="mt-4 grid gap-2 text-sm">
          <li>
            <a href={`mailto:${site.email}`} class="text-muted hover:text-white"
              >{site.email}</a>
          </li>
          <li>
            <a href={site.phoneHref} class="text-muted hover:text-white"
              >{site.phone}</a>
          </li>
        </ul>
      </div>
      <div>
        <h2 class="font-display text-xl font-bold text-white">Rechtliches</h2>
        <ul class="mt-4 grid gap-2 text-sm">
          <li>
            <a href="/impressum/" class="text-muted hover:text-white"
              >Impressum</a>
          </li>
          <li>
            <a href="/privacy-statement/" class="text-muted hover:text-white"
              >Datenschutz</a>
          </li>
        </ul>
      </div>
      <div>
        <h2 class="font-display text-xl font-bold text-white">Social</h2>
        <div class="mt-4 flex gap-3">
          <a
            href={site.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/20 text-white hover:bg-white hover:text-brand"
          >
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"
              ><path
                d="M13.5 21v-8h2.7l.4-3h-3.1V8.1c0-.9.3-1.5 1.6-1.5h1.7V3.9c-.3 0-1.2-.1-2.3-.1-2.3 0-3.9 1.4-3.9 4V10H8v3h2.6v8h2.9Z"
              ></path></svg
            >
          </a>
          <a
            href={site.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/20 text-white hover:bg-white hover:text-brand"
          >
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"
              ><path
                d="M7.8 3h8.4A4.8 4.8 0 0 1 21 7.8v8.4a4.8 4.8 0 0 1-4.8 4.8H7.8A4.8 4.8 0 0 1 3 16.2V7.8A4.8 4.8 0 0 1 7.8 3Zm0 1.8A3 3 0 0 0 4.8 7.8v8.4a3 3 0 0 0 3 3h8.4a3 3 0 0 0 3-3V7.8a3 3 0 0 0-3-3H7.8Zm8.85 1.35a1.05 1.05 0 1 1 0 2.1 1.05 1.05 0 0 1 0-2.1ZM12 7.5A4.5 4.5 0 1 1 7.5 12 4.5 4.5 0 0 1 12 7.5Zm0 1.8A2.7 2.7 0 1 0 14.7 12 2.7 2.7 0 0 0 12 9.3Z"
              ></path></svg
            >
          </a>
        </div>
      </div>
    </div>
    <div
      class="mt-10 flex flex-col gap-2 border-t border-white/10 pt-6 text-xs text-brand-soft"
    >
      <p>
        Copyright © <span id="footer-year">2023</span> Matratzen Outlet Kamp-Lintfort
      </p>
      <p>
        Proudly crafted by
        <a
          href="https://beary.cloud"
          target="_blank"
          rel="noopener noreferrer"
          class="underline-offset-2 hover:text-white hover:underline"
        >
          bearylabs
        </a>
      </p>
    </div>
  </div>
</footer>

<script>
  const yearEl = document.getElementById("footer-year");

  if (yearEl) {
    yearEl.textContent = String(new Date().getFullYear());
  }
</script>
