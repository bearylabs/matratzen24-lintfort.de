---
import StandardPage from "@/components/StandardPage.astro";
---

<StandardPage
  title="Vielen Dank | Matratzen Outlet Lintfort"
  description="Vielen Dank für Ihre Nachricht."
  mainClass="section-wrap pt-40"
>
  <div class="mx-auto max-w-3xl rounded-3xl bg-white p-10 text-center shadow-xl">
    <h1 class="section-title">Vielen Dank für deine Nachricht</h1>
    <p class="mx-auto mt-6 max-w-2xl">
      Wir melden uns so schnell wie möglich bei dir zurück. Wenn es eilt,
      erreichst du uns auch telefonisch.
    </p>
    <a href="/" class="pill-button mt-8">Zurück zur Startseite</a>
  </div>
</StandardPage>
