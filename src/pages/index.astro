---
import BaseLayout from "@/components/BaseLayout.astro";
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import {
  about,
  openingHours,
  routeInfo,
  site,
  sliderImages,
  warehouse,
} from "@/lib/site";
---

<BaseLayout>
  <div class="page-shell">
    <Header />

    <main>
      <section
        id="start"
        class="relative isolate flex min-h-[92vh] items-center overflow-hidden bg-brand bg-cover bg-center bg-no-repeat pt-40 text-white md:bg-fixed md:pt-44"
        style={`background-image: linear-gradient(rgba(20,67,132,0.22), rgba(20,67,132,0.58)), url('${site.heroImage}')`}
      >
        <div
          class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.24),transparent_34%),radial-gradient(circle_at_right,rgba(255,255,255,0.14),transparent_28%)]"
        >
        </div>
        <div
          class="absolute inset-x-0 bottom-0 h-40 bg-linear-to-t from-brand/45 to-transparent"
        >
        </div>
        <div class="section-wrap w-full">
          <div
            class="relative z-10 grid items-end gap-10 lg:grid-cols-[minmax(0,1.2fr)_minmax(280px,0.62fr)]"
          >
            <div class="max-w-4xl p-8 md:p-10">
              <p
                class="inline-flex rounded-full border border-white/25 bg-white/14 px-4 py-2 text-sm font-semibold uppercase tracking-[0.16em] text-white/90"
              >
                Lagerverkauf in Kamp-Lintfort
              </p>
              <h1
                class="mt-6 max-w-3xl font-display text-[48px] leading-[1.05] text-white md:text-[72px]"
              >
                Hochwertige Matratzen zu unschlagbaren Preisen
              </h1>
              <p
                class="mt-6 max-w-2xl text-lg text-white/92 md:text-[22px] md:leading-[1.6]"
              >
                Bei uns bekommst du die besten Preise, direkt aus dem Lager
              </p>
              <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
                <a
                  href="#anfahrt"
                  class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-base font-semibold text-brand shadow-lg shadow-black/10 transition-transform duration-200 hover:-translate-y-0.5"
                >
                  Komm uns besuchen
                </a>
                <a
                  href={site.phoneHref}
                  class="inline-flex items-center justify-center rounded-full border border-white/45 px-6 py-3 text-base font-semibold text-white transition-colors duration-200 hover:bg-white/12"
                >
                  {site.phone}
                </a>
              </div>
              <div
                class="mt-8 flex flex-wrap gap-3 text-sm font-semibold text-white/92"
              >
                <span
                  class="rounded-full bg-white/14 px-4 py-2 backdrop-blur-sm"
                  >1600+ Matratzen</span
                >
                <span
                  class="rounded-full bg-white/14 px-4 py-2 backdrop-blur-sm"
                  >Bis zu 70% Rabatt</span
                >
                <span
                  class="rounded-full bg-white/14 px-4 py-2 backdrop-blur-sm"
                  >Direkt ab Lager</span
                >
              </div>
            </div>

            <div
              class="hidden rounded-[28px] border border-white/22 bg-brand/50 p-6 shadow-[0_24px_80px_rgba(4,24,55,0.24)] backdrop-blur-sm lg:block"
            >
              <p
                class="text-sm font-semibold uppercase tracking-[0.16em] text-white/70"
              >
                Vor Ort
              </p>
              <div class="mt-5 space-y-5">
                <div class="rounded-2xl bg-white/10 p-4">
                  <p
                    class="text-xs font-semibold uppercase tracking-[0.14em] text-white/65"
                  >
                    Adresse
                  </p>
                  <p class="mt-2 text-lg font-semibold text-white">
                    {site.address[0]}
                  </p>
                  <p class="text-white/82">{site.address[1]}</p>
                </div>
                <div class="rounded-2xl bg-white/10 p-4">
                  <p
                    class="text-xs font-semibold uppercase tracking-[0.14em] text-white/65"
                  >
                    Öffnungszeiten
                  </p>
                  <div class="mt-3 space-y-2 text-sm text-white/88">
                    {
                      openingHours.map((item) => (
                        <p class="flex items-center justify-between gap-4 border-b border-white/10 pb-2 last:border-b-0 last:pb-0">
                          <span>{item.day}</span>
                          <span class="font-semibold text-white">
                            {item.hours}
                          </span>
                        </p>
                      ))
                    }
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div
          class="absolute inset-x-0 bottom-0 h-20 bg-white [clip-path:polygon(0_45%,100%_0,100%_100%,0_100%)] md:h-28"
        >
        </div>
      </section>

      <section id="lagerverkauf" class="relative bg-white text-center">
        <div
          class="section-wrap flex flex-col items-center pb-0 pt-15 md:pb-15"
        >
          <h2 class="section-title">Matratzen Lagerverkauf</h2>
          <p class="mt-6 max-w-4xl text-[24px] leading-[1.4] md:text-[28px]">
            Im Matratzen Outlet Lintfort findest du Testsieger Matratzen und
            weitere Bettwaren zu den besten Preisen im Lagerverkauf.
            <br /><br />
            Bis zu 70% Rabatt auf alle bekannten Marken Matratzen.
          </p>

          <div
            class="mt-10 grid w-full place-items-center gap-2 text-white md:grid-cols-2 lg:grid-cols-3"
          >
            <article class="info-card">
              <div class="mb-4 text-brand">
                <svg
                  viewBox="0 0 24 24"
                  class="h-14 w-14"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                >
                  <circle cx="12" cy="12" r="8.25"></circle>
                  <path
                    d="M12 7.8v4.8l3 1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </div>
              <h3 class="text-2xl">Öffnungszeiten</h3>
              <div class="mt-4 text-center text-text">
                {
                  openingHours.map((item) => (
                    <p class="mb-5 last:mb-0">
                      {item.day}
                      <br />
                      {item.hours}
                    </p>
                  ))
                }
              </div>
            </article>

            <article class="info-card order-3 md:order-0">
              <div class="mb-4 text-brand">
                <svg
                  viewBox="0 0 24 24"
                  class="h-14 w-14"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                >
                  <path
                    d="M12 21s6-5.25 6-11.25A6 6 0 1 0 6 9.75C6 15.75 12 21 12 21Z"
                  ></path>
                  <circle cx="12" cy="9.75" r="2.4"></circle>
                </svg>
              </div>
              <h3 class="text-2xl">Google Maps</h3>
              <a
                href={site.mapsUrl}
                class="pill-button mt-4"
                target="_blank"
                rel="noopener noreferrer"
              >
                Navigation
              </a>
            </article>

            <article class="info-card">
              <div class="mb-4 text-brand">
                <svg
                  viewBox="0 0 24 24"
                  class="h-14 w-14"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                >
                  <path
                    d="M4 10.5 12 5l8 5.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                  <path
                    d="M5.5 10.5V19h13v-8.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                  <path
                    d="M9 19v-4h6v4"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                  <path
                    d="M8 12.5h.01M12 12.5h.01M16 12.5h.01"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </div>
              <h3 class="text-2xl">Adresse</h3>
              <p class="mt-4 text-center text-text">
                {site.address[0]}
                <br />
                {site.address[1]}
              </p>
            </article>
          </div>

          <h2 id="anfahrt" class="section-title mt-10">Wegbeschreibung</h2>
          <div class="mt-4 max-w-5xl space-y-2 text-center">
            {routeInfo.text.map((paragraph) => <p>{paragraph}</p>)}
          </div>
          <div class="mt-8 w-full">
            <iframe
              title="Google Maps - Matratzen Outlet Kamp-Lintfort"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2483.7924382861206!2d6.565769915746529!3d51.49867631916196!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47b8a3023256f2f9%3A0xcf516b6d1403f931!2sMatratzen%20Outlet%20Kamp-Lintfort!5e0!3m2!1sde!2sde!4v1651513041099!5m2!1sde!2sde"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="h-112.5 w-full border-0"></iframe>
          </div>
        </div>
      </section>

      <section class="bg-white">
        <div class="relative overflow-hidden">
          <div
            class="flex snap-x snap-mandatory overflow-x-auto"
            data-slider-track
          >
            {
              sliderImages.map((src, index) => (
                <div
                  class="min-w-full snap-center"
                  aria-hidden={index === 0 ? "false" : "true"}
                >
                  <img
                    src={src}
                    alt=""
                    loading={index === 0 ? "eager" : "lazy"}
                    decoding="async"
                    class="h-[60vh] w-full object-cover"
                  />
                </div>
              ))
            }
          </div>
          <div
            class="pointer-events-none absolute inset-x-0 bottom-5 flex justify-center gap-2"
          >
            {
              sliderImages.map((_, index) => (
                <button
                  type="button"
                  class:list={[
                    "pointer-events-auto h-3 w-3 rounded-full border border-white/80 bg-transparent",
                    index === 0 && "bg-white",
                  ]}
                  aria-label={`Slide ${index + 1}`}
                  data-slide-dot
                  data-slide-index={index}
                />
              ))
            }
          </div>
        </div>
      </section>

      <section id="ueber-uns" class="bg-brand text-white">
        <div class="section-wrap pb-11">
          <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_0.9fr]">
            <div>
              <p class="subheading text-brand-soft">{about.title}</p>
              <div class="mt-6 space-y-6">
                {about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            </div>
            <div>
              <img
                src={about.image}
                alt={about.imageAlt}
                width="1024"
                height="768"
                loading="lazy"
                decoding="async"
                class="w-full rounded-2xl object-cover shadow-xl"
              />
            </div>
          </div>
        </div>
        <div
          class="h-20 bg-brand-soft [clip-path:polygon(0_0,100%_55%,100%_100%,0_100%)] md:h-24"
        >
        </div>
      </section>

      <section class="relative bg-brand-soft">
        <div
          class="pointer-events-none absolute -top-8 left-[12%] h-62.5 w-62.5 rounded-full bg-white/70"
        >
        </div>
        <div
          class="pointer-events-none absolute top-56 right-[20%] h-75 w-75 rounded-full bg-white/70"
        >
        </div>
        <div
          class="pointer-events-none absolute top-84 right-[15%] h-50 w-50 rounded-full bg-muted/60"
        >
        </div>

        <div class="section-wrap relative z-10 pt-15">
          <div class="grid gap-10 lg:grid-cols-2">
            <div class="relative">
              <p class="subheading">{warehouse.subheading}</p>
              <h2 class="section-title mt-3">{warehouse.title}</h2>
              <div class="mt-8">
                <img
                  src={warehouse.images[0].src}
                  alt={warehouse.images[0].alt}
                  width="1024"
                  height="768"
                  loading="lazy"
                  decoding="async"
                  class="w-full rounded-2xl object-cover shadow-xl"
                />
              </div>
              <p class="mt-8 max-w-xl">{warehouse.copy}</p>
            </div>

            <div class="flex flex-col gap-8 pt-4 md:pt-0">
              <img
                src={warehouse.images[1].src}
                alt={warehouse.images[1].alt}
                width="1024"
                height="768"
                loading="lazy"
                decoding="async"
                class="w-full rounded-2xl object-cover shadow-xl"
              />
              <img
                src={warehouse.images[2].src}
                alt={warehouse.images[2].alt}
                width="1024"
                height="808"
                loading="lazy"
                decoding="async"
                class="w-full rounded-2xl object-cover shadow-xl"
              />
            </div>
          </div>
        </div>
      </section>

      <section id="kontakt" class="bg-brand-soft text-center">
        <div class="section-wrap flex flex-col items-center pt-12 md:pt-15">
          <p class="subheading">Noch fragen?</p>
          <h2 class="section-title mt-3">
            Hinterlass uns einfach eine Nachricht
          </h2>

          <div class="contact-panel mt-12">
            <div class="mb-7 flex justify-center text-brand-soft">
              <svg
                viewBox="0 0 24 24"
                class="h-9 w-9"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
              >
                <rect x="3" y="6" width="18" height="12" rx="2"></rect>
                <path
                  d="m5 8 7 5 7-5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </div>

            <form
              name="kontakt"
              method="POST"
              action="/danke/"
              data-netlify="true"
              netlify-honeypot="bot-field"
              class="grid gap-5"
            >
              <p class="hidden">
                <label>
                  Nicht ausfüllen:
                  <input name="bot-field" type="text" />
                </label>
              </p>

              <label class="sr-only" for="name">Name</label>
              <input
                id="name"
                name="name"
                type="text"
                required
                placeholder="Name"
                class="rounded-md border border-white/20 bg-white px-4 py-3 text-text outline-none ring-0 placeholder:text-text/65 focus:border-white"
              />

              <label class="sr-only" for="phone">Telefon</label>
              <input
                id="phone"
                name="phone"
                type="text"
                placeholder="Telefon (Optional)"
                class="rounded-md border border-white/20 bg-white px-4 py-3 text-text outline-none ring-0 placeholder:text-text/65 focus:border-white"
              />

              <label class="sr-only" for="email">Email</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                placeholder="Email"
                class="rounded-md border border-white/20 bg-white px-4 py-3 text-text outline-none ring-0 placeholder:text-text/65 focus:border-white"
              />

              <label class="sr-only" for="message">Nachricht</label>
              <textarea
                id="message"
                name="message"
                required
                placeholder="Nachricht"
                rows="6"
                class="rounded-md border border-white/20 bg-white px-4 py-3 text-text outline-none ring-0 placeholder:text-text/65 focus:border-white"
              ></textarea>

              <div class="pt-2 text-center">
                <button type="submit" class="hero-button border-white"
                  >Nachricht senden</button
                >
              </div>
            </form>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>

  <script is:inline src="/scripts/site.js"></script>
</BaseLayout>
